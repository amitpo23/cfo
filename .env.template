# Environment Variables Configuration

# SUMIT API Configuration (Required)
SUMIT_API_KEY=your_sumit_api_key_here
SUMIT_COMPANY_ID=your_company_id_here

# Database Configuration
DATABASE_URL=sqlite:///./cfo.db

# Application Settings
APP_NAME=CFO Management System
DEBUG=False
LOG_LEVEL=INFO
TIMEZONE=Asia/Jerusalem

# Security
JWT_SECRET_KEY=change_this_to_a_long_random_jwt_secret
CREDENTIALS_ENCRYPTION_KEY=change_this_to_a_separate_long_random_secret
REGISTRATION_SECRET=change_this_to_a_private_invite_code
CRON_SECRET=change_this_to_a_long_random_cron_secret
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
OPEN_FINANCE_WEBHOOK_SECRET=change_this_to_a_webhook_shared_secret
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# Optional
OPENAI_API_KEY=your_openai_api_key_for_ai_insights
