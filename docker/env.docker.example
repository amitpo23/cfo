# Safe local Docker defaults. Copy to docker/.env.docker if you want private
# local overrides, then point docker compose at it manually.
APP_NAME=Rezef Local
DEBUG=true
LOG_LEVEL=INFO
TIMEZONE=Asia/Jerusalem

JWT_SECRET_KEY=local-docker-jwt-secret-change-me-32-chars-minimum
CREDENTIALS_ENCRYPTION_KEY=local-docker-credentials-secret-32-chars-minimum
AUTH_BYPASS_ENABLED=true
REGISTRATION_SECRET=local-register
CRON_SECRET=local-cron-secret
OPEN_FINANCE_WEBHOOK_SECRET=local-open-finance-webhook-secret

# Optional integrations. Leave empty for integration-gated UI states.
SUMIT_API_KEY=
SUMIT_COMPANY_ID=
OPEN_FINANCE_CLIENT_ID=
OPEN_FINANCE_CLIENT_SECRET=
OPEN_FINANCE_USER_ID=
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional billing.
STRIPE_SECRET_KEY=
STRIPE_PRICE_COMPANY_UP_TO_2_5M=
STRIPE_PRICE_COMPANY_ABOVE_2_5M=
STRIPE_PRICE_OFFICE=
