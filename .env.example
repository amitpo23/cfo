# Database Configuration
DATABASE_URL=sqlite:///./cfo.db
# For PostgreSQL: postgresql://user:password@localhost/cfo_db

# Security & JWT
JWT_SECRET_KEY=CHANGE-THIS-IN-PRODUCTION-USE-LONG-RANDOM-STRING-MIN-32-CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# API Keys for Accounting Systems
QUICKBOOKS_CLIENT_ID=your_quickbooks_client_id
QUICKBOOKS_CLIENT_SECRET=your_quickbooks_client_secret
QUICKBOOKS_REALM_ID=your_realm_id

XERO_CLIENT_ID=your_xero_client_id
XERO_CLIENT_SECRET=your_xero_client_secret

# SUMIT API (Israeli Accounting)
SUMIT_API_KEY=your_sumit_api_key
SUMIT_COMPANY_ID=your_company_id

# Open Finance API (Israeli Open Banking / Financy)
OPEN_FINANCE_CLIENT_ID=your_open_finance_client_id
OPEN_FINANCE_CLIENT_SECRET=your_open_finance_client_secret
OPEN_FINANCE_USER_ID=your_internal_user_id
OPEN_FINANCE_API_BASE_URL=https://api.open-finance.ai/v2
OPEN_FINANCE_OAUTH_URL=https://api.open-finance.ai/oauth/token

# OpenAI for Financial Insights
OPENAI_API_KEY=your_openai_api_key

# Application Settings
APP_NAME=CFO Management System
DEBUG=True
LOG_LEVEL=INFO

# Report Settings
REPORTS_OUTPUT_DIR=./reports
TIMEZONE=Asia/Jerusalem
